# MySQL — pick ONE method:
#
# Method A (recommended on Plesk): single connection URL
# DATABASE_URL=mysql://plesk_db_user:plesk_db_password@127.0.0.1:3306/plesk_db_name
#
# Method B: separate variables (use 127.0.0.1, not localhost)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_plesk_db_user
MYSQL_PASSWORD=your_plesk_db_password
MYSQL_DATABASE=your_plesk_db_name
# MYSQL_SOCKET=/var/run/mysqld/mysqld.sock

# Microsoft Entra ID (Azure AD) — single-tenant SSO
AZURE_TENANT_ID=your-directory-tenant-id
AZURE_CLIENT_ID=your-application-client-id
AZURE_CLIENT_SECRET=your-client-secret-value
AZURE_REDIRECT_URI=http://localhost:8080/auth/microsoft/callback
# Production (must match Azure App registration exactly, no /api prefix):
# AZURE_REDIRECT_URI=https://nims.rcmp.edu.my/auth/microsoft/callback
AZURE_ALLOWED_EMAIL_DOMAINS=

# Client: show Microsoft button when server vars are set (set false to hide in dev)
VITE_MICROSOFT_SSO_ENABLED=true

# Temporary dev-only user sign-in with email only (no password). Enabled by default in dev.
# ALLOW_EMAIL_ONLY_USER_LOGIN=true
# VITE_ALLOW_EMAIL_ONLY_USER_LOGIN=true

# Notification email (Microsoft 365 / Outlook SMTP) — system mailbox only, not stored in DB
# Use an app password if the account has MFA: https://account.microsoft.com/security
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-notifications@yourorg.onmicrosoft.com
# SMTP_PASSWORD=your-mailbox-password-or-app-password
# SMTP_FROM=your-notifications@yourorg.onmicrosoft.com
# SMTP_FROM_NAME=NIMS

# --- Local dev with Mailpit (see .env.mailpit.example and config/mailpit.env) ---
# npm run mailpit  →  UI http://localhost:8025  SMTP localhost:1025
SMTP_MAILPIT=true
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=nims.rcmp@unikl.edu.my
SMTP_PASSWORD=
SMTP_FROM=nims.rcmp@unikl.edu.my
SMTP_FROM_NAME=NIMS

# Overdue return reminder emails (daily 09:00 Asia/Kuala_Lumpur)
# First send the calendar day after return_date; repeats daily while assets stay checked out.
# OVERDUE_EMAIL_TZ=Asia/Kuala_Lumpur
# OVERDUE_EMAIL_HOUR=9
# OVERDUE_EMAIL_MINUTE=0
# OVERDUE_EMAIL_SCHEDULER=true
# CRON_SECRET=change-me-for-post-api-cron-overdue-return-emails

# OAuth scopes requested at sign-in (must include User.Read for Graph profile)
AZURE_OAUTH_SCOPES=openid profile email offline_access User.Read
# Microsoft Graph API — profile fetch for Settings page
AZURE_GRAPH_API_URL=https://graph.microsoft.com/v1.0
AZURE_GRAPH_ME_PATH=/me
AZURE_GRAPH_ME_SELECT=id,displayName,mail,userPrincipalName,jobTitle,officeLocation
