# MySQL
# Local dev: import database/schema.sql (creates nimsV2)
# Shared server: import database/schema-tables-only.sql in phpMyAdmin; use the DB name from your host (e.g. nimsv2)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=nimsV2

# Microsoft Entra ID (Azure AD) — single-tenant SSO
# Register an app in Entra ID → App registrations. See docs/AZURE_SSO_SETUP.md
AZURE_TENANT_ID=your-directory-tenant-id
AZURE_CLIENT_ID=your-application-client-id
AZURE_CLIENT_SECRET=your-client-secret-value
# Must match a redirect URI configured in Entra (SPA/Web platform)
AZURE_REDIRECT_URI=http://localhost:8080/auth/microsoft/callback
# Optional: comma-separated allowed email domains (e.g. rcmp-grc.gc.ca,rcmp.ca)
AZURE_ALLOWED_EMAIL_DOMAINS=

# Client: show Microsoft button when server vars are set (set false to hide in dev)
VITE_MICROSOFT_SSO_ENABLED=true

# Notification email (Microsoft 365 / Outlook SMTP) — system mailbox only, not stored in DB
# Use an app password if the account has MFA: https://account.microsoft.com/security
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-notifications@yourorg.onmicrosoft.com
SMTP_PASSWORD=your-mailbox-password-or-app-password
SMTP_FROM=your-notifications@yourorg.onmicrosoft.com
SMTP_FROM_NAME=NIMS

# --- Local dev with Mailpit (see .env.mailpit.example and config/mailpit.env) ---
# npm run mailpit  →  UI http://localhost:8025  SMTP localhost:1025
SMTP_MAILPIT=true
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=nims.rcmp@unikl.edu.my
SMTP_PASSWORD=
SMTP_FROM=nims.rcmp@unikl.edu.my
SMTP_FROM_NAME=NIMS